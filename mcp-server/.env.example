# Google AI Studio API Key (free tier at aistudio.google.com)
GEMINI_API_KEY=your_gemini_key_here

# OpenAI API Key (optional - for GPT-4o-mini experimentation)
OPENAI_API_KEY=your_openai_key_here

# Anthropic API Key (optional - for Claude-3-5-Haiku experimentation)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Groq API Key (optional - free tier at console.groq.com)
GROQ_API_KEY=your_groq_key_here

# Ollama settings (for completely free offline local models)
# Requires Ollama running locally (ollama run qwen2.5-coder)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# MCP Server Port
PORT=3001

# Allowed CORS Origins (comma-separated list)
ALLOWED_ORIGINS=https://gtmcontaineranalyzer.com,http://localhost:5173

# Allowed Base Directory for local file access (stdio mode)
# Default is the current working directory
ALLOWED_BASE_DIR=.
